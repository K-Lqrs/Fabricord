{
	"schemaVersion": 1,
	"id": "fabricord",
	"version": "${version}",
	"name": "Fabricord",
	"description": "${description}",
	"contributors": [
		"Lars"
	],
	"contact": {
		"sources": "https://github.com/K-Lqrs/Fabricord"
	},
	"license": "Apache-2.0",
	"icon": "assets/fabricord/icon.png",
	"environment": "server",
	"entrypoints": {
		"server": [
			{
				"adapter": "kotlin",
				"value": "net.rk4z.fabricord.Fabricord"
			}
		]
	},
	"mixins": [
		"fabricord.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.16.9",
		"minecraft": "~1.21",
		"java": ">=21",
		"fabric-api": ">=0.107.0+1.21.3",
		"fabric-language-kotlin": ">=1.12.3+kotlin.2.0.21"
	}
}